    "eslint-plugin-tsdoc": "^0.2.17",
    "jest-fetch-mock": "^3.0.3",
    "remove": "^0.1.5",
    "testing": "link:@nrwl/nx-plugin/testing",
    "ts-jest": "^29.1.1",
    "tsc": "^2.0.4",
    "typedoc": "^0.25.3",
    "typescript": "^5.2.2",
    "vite": "^4.5.0",
